    <script>
        const songs = ["Backsound1.mp3", "Backsound2.mp3", "Backsound3.mp3"];
        const songTitles = [
            "Everybody Wants to Rule the World - Tears for Fears",
            "What You Won't Do For Love - Bobby Caldwell",
            "Put Your Head On My Shoulder - Paul Anka"
        ];
        
        let currentIdx = 0;
        const audio = document.getElementById('bgm');
        const btnPlay = document.getElementById('btn-play-pause');
        const disk = document.getElementById('vinyl-disk');
        const title = document.getElementById('song-title');
        const progress = document.getElementById('progress');
        const currTimeText = document.getElementById('current-time');
        const totalDurationText = document.getElementById('total-duration');
        const visualizer = document.getElementById('visualizer');
        const seekBar = document.getElementById('seek-bar');
        let isDraggingSeek = false;

        function setPlayIcon() {
            btnPlay.style.filter = 'none';
            btnPlay.src = "play.png";
            btnPlay.onerror = function() {
                this.onerror = null; 
                this.src = 'https://cdn-icons-png.flaticon.com/512/0/375.png'; 
                this.style.filter = 'invert(1)';
            };
        }

        function setPauseIcon() {
            btnPlay.style.filter = 'none';
            btnPlay.src = "pause.png";
            btnPlay.onerror = function() {
                this.onerror = null;
                this.src = 'https://cdn-icons-png.flaticon.com/512/16/16427.png'; 
                this.style.filter = 'invert(1)';
            };
        }

        setPlayIcon();

        function formatTime(seconds) {
            if (isNaN(seconds)) return "0:00";
            const min = Math.floor(seconds / 60);
            const sec = Math.floor(seconds % 60);
            return min + ":" + (sec < 10 ? "0" + sec : sec);
        }

        function loadSong(idx) {
            audio.src = songs[idx];
            title.textContent = songTitles[idx];
            audio.load();
        }

        function togglePlay() {
            if (audio.paused) {
                audio.play();
                setPauseIcon();
                visualizer.classList.add('wave-active');
            } else {
                audio.pause();
                setPlayIcon();
                visualizer.classList.remove('wave-active');
            }
        }

        function nextSong() {
            currentIdx = (currentIdx + 1) % songs.length;
            loadSong(currentIdx);
            audio.play();
            setPauseIcon();
            visualizer.classList.add('wave-active');
        }

        function prevSong() {
            currentIdx = (currentIdx - 1 + songs.length) % songs.length;
            loadSong(currentIdx);
            audio.play();
            setPauseIcon();
            visualizer.classList.add('wave-active');
        }

        audio.ontimeupdate = () => {
            if (!isDraggingSeek) {
                const pct = (audio.currentTime / audio.duration) * 100;
                progress.style.width = pct + "%";
                currTimeText.textContent = formatTime(audio.currentTime);
            }
        };

        audio.onloadedmetadata = () => {
            totalDurationText.textContent = formatTime(audio.duration);
        };

        audio.onended = nextSong;

        function updateSeekPosition(e) {
            const rect = seekBar.getBoundingClientRect();
            let clientX = e.touches ? e.touches[0].clientX : e.clientX;
            let x = clientX - rect.left;
            if (x < 0) x = 0;
            if (x > rect.width) x = rect.width;
            const pct = (x / rect.width) * 100;
            progress.style.width = pct + "%";
            if (audio.duration) {
                const dragTime = (x / rect.width) * audio.duration;
                currTimeText.textContent = formatTime(dragTime);
            }
        }

        function startSeekDrag(e) {
            isDraggingSeek = true;
            updateSeekPosition(e); 
            document.addEventListener('mousemove', seekDrag);
            document.addEventListener('touchmove', seekDrag, { passive: false });
            document.addEventListener('mouseup', endSeekDrag);
            document.addEventListener('touchend', endSeekDrag);
        }

        function seekDrag(e) {
            if (!isDraggingSeek) return;
            e.preventDefault(); 
            updateSeekPosition(e);
        }

        function endSeekDrag(e) {
            if (!isDraggingSeek) return;
            isDraggingSeek = false;
            const rect = seekBar.getBoundingClientRect();
            let clientX = e.changedTouches ? e.changedTouches[0].clientX : e.clientX;
            let x = clientX - rect.left;
            if (x < 0) x = 0;
            if (x > rect.width) x = rect.width;
            if (audio.duration) {
                audio.currentTime = (x / rect.width) * audio.duration;
            }
            document.removeEventListener('mousemove', seekDrag);
            document.removeEventListener('touchmove', seekDrag);
            document.removeEventListener('mouseup', endSeekDrag);
            document.removeEventListener('touchend', endSeekDrag);
        }

        seekBar.addEventListener('mousedown', startSeekDrag);
        seekBar.addEventListener('touchstart', startSeekDrag, { passive: false });

        function startPorto() {
            loadSong(currentIdx);
            audio.play().then(() => {
                setPauseIcon();
                visualizer.classList.add('wave-active');
            }).catch(() => {});
            const overlay = document.getElementById('welcome-overlay');
            const main = document.getElementById('main-content');
            overlay.style.opacity = '0';
            setTimeout(() => {
                overlay.style.display = 'none';
                main.style.display = 'block';
                setTimeout(() => { main.style.opacity = '1'; typingEffect(); }, 50);
            }, 800);
        }

        let currentRotation = 0;
        let isDragging = false;
        let startAngle = 0;
        let lastRotation = 0;

        function getAngle(e) {
            const rect = disk.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;
            const clientX = e.touches ? e.touches[0].clientX : e.clientX;
            const clientY = e.touches ? e.touches[0].clientY : e.clientY;
            return Math.atan2(clientY - centerY, clientX - centerX) * (180 / Math.PI);
        }

        disk.addEventListener('mousedown', startDrag);
        disk.addEventListener('touchstart', startDrag, {passive: false});

        function startDrag(e) {
            isDragging = true;
            startAngle = getAngle(e);
            lastRotation = currentRotation;
            document.addEventListener('mousemove', drag);
            document.addEventListener('touchmove', drag, {passive: false});
            document.addEventListener('mouseup', endDrag);
            document.addEventListener('touchend', endDrag);
        }

        function drag(e) {
            if (!isDragging) return;
            e.preventDefault(); 
            const angle = getAngle(e);
            let delta = angle - startAngle;
            if (delta > 180) delta -= 360;
            if (delta < -180) delta += 360;
            currentRotation = lastRotation + delta;
            disk.style.transform = `rotate(${currentRotation}deg)`;
            if(audio.duration) {
                let targetTime = audio.currentTime + (delta * 0.03); 
                if(targetTime < 0) targetTime = 0;
                if(targetTime > audio.duration) targetTime = audio.duration;
                audio.currentTime = targetTime;
            }
            startAngle = angle;
            lastRotation = currentRotation;
        }

        function endDrag() {
            isDragging = false;
            document.removeEventListener('mousemove', drag);
            document.removeEventListener('touchmove', drag);
            document.removeEventListener('mouseup', endDrag);
            document.removeEventListener('touchend', endDrag);
        }

        function spinDiskAuto() {
            if (!isDragging && !audio.paused) {
                currentRotation += 0.6; 
                disk.style.transform = `rotate(${currentRotation}deg)`;
            }
            requestAnimationFrame(spinDiskAuto);
        }
        spinDiskAuto(); 

        function updateClock() {
            const now = new Date();
            document.getElementById('time-display').textContent = `[${String(now.getHours()).padStart(2, '0')}.${String(now.getMinutes()).padStart(2, '0')}.${String(now.getSeconds()).padStart(2, '0')}] WIB`;
        }
        setInterval(updateClock, 1000);
        updateClock();

        const typeTarget = document.getElementById('type-text');
        const textArray = ["membuat website itu sulit boss.", "nyontek afkar dikit", "bisa any stuff kek afkar"];
        let textIndex = 0, charIndex = 0, isDeleting = false;

        function typingEffect() {
            if(!typeTarget) return;
            const currentText = textArray[textIndex];
            if (!isDeleting && charIndex <= currentText.length) {
                typeTarget.textContent = currentText.substring(0, charIndex);
                charIndex++;
                setTimeout(typingEffect, 100);
            } else if (isDeleting && charIndex >= 0) {
                typeTarget.textContent = currentText.substring(0, charIndex);
                charIndex--;
                setTimeout(typingEffect, 50);
            } else if (!isDeleting && charIndex > currentText.length) {
                isDeleting = true;
                setTimeout(typingEffect, 3000);
            } else {
                isDeleting = false;
                charIndex = 0;
                textIndex = (textIndex + 1) % textArray.length;
                setTimeout(typingEffect, 500);
            }
        }
    </script>
