<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gen Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-deep: #050a18;
            --accent-blue: #3b82f6;
            --card-bg: rgba(255, 255, 255, 0.05);
        }

        body {
            background-color: var(--bg-deep);
            color: white;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .bg-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: radial-gradient(circle at top right, #1e293b 0%, #050a18 60%);
        }

        /* Welcome Overlay */
        #welcome-overlay {
            position: fixed;
            inset: 0;
            background: #050a18;
            z-index: 100;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            transition: opacity 0.8s ease, visibility 0.8s;
        }

        .welcome-text {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: 4px;
            color: #60a5fa;
            animation: pulse-text 2s infinite;
            text-align: center;
        }

        @keyframes pulse-text {
            0%, 100% { opacity: 0.4; transform: scale(0.95); }
            50% { opacity: 1; transform: scale(1); }
        }

        /* Main Content Layout */
        .main-wrapper {
            display: none; 
            opacity: 0;
            transition: opacity 1s ease;
            padding: 20px 0 60px 0;
            width: 100%;
        }

        .container-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
            width: 90%;
            max-width: 1000px;
            margin: 0 auto;
            justify-items: center;
        }

        @media (min-width: 768px) {
            .container-grid { grid-template-columns: 1fr 1fr; }
            .full-row { grid-column: span 2; }
        }

        .glass-card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            width: 100%;
            max-width: 450px;
            padding: 24px;
            position: relative;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            height: fit-content;
        }

        .text-gen {
            font-size: 3.5rem;
            font-weight: 800;
            background: linear-gradient(to bottom, #60a5fa, #2563eb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1;
            margin-bottom: 5px;
        }

        .username { color: #94a3b8; font-size: 1rem; font-weight: 500; opacity: 0.8; }
        .info-sub { font-size: 0.75rem; color: #64748b; margin-top: 5px; }

        .typewriter-box {
            margin-top: 25px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.9rem;
            color: #e2e8f0;
            min-height: 45px;
            line-height: 1.5;
        }

        .pfp-container {
            position: absolute;
            right: 20px;
            top: 40px;
            width: 80px;
            height: 80px;
            cursor: pointer;
            z-index: 20;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @media (min-width: 400px) {
            .pfp-container { width: 100px; height: 100px; right: 30px; top: 50px; }
        }

        .pfp-container:hover { transform: scale(1.1) rotate(5deg); }
        .pfp-img {
            width: 100%; height: 100%; border-radius: 50%; object-fit: cover;
            border: 3px solid rgba(59, 130, 246, 0.5);
            animation: slow-spin 12s linear infinite;
        }

        @keyframes slow-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

        .list-item { margin-bottom: 12px; }
        .list-label { display: block; font-size: 0.7rem; text-transform: uppercase; color: var(--accent-blue); letter-spacing: 1px; font-weight: 800; }
        .list-value { font-size: 0.9rem; color: #cbd5e1; }

        .orbit-wrap {
            height: 250px;
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .orbit-circle { position: absolute; width: 180px; height: 180px; border: 1px dashed rgba(255,255,255,0.1); border-radius: 50%; }
        .center-box { width: 60px; height: 60px; background: #000; border: 2px solid #4ade80; border-radius: 12px; z-index: 5; overflow: hidden; }
        .center-box img { width: 100%; height: 100%; object-fit: cover; }
        .orb-icon {
            position: absolute; width: 40px; height: 40px; background: #111827; border: 1px solid rgba(255,255,255,0.1);
            border-radius: 50%; display: flex; justify-content: center; align-items: center;
            animation: orbit-anim 15s linear infinite; overflow: hidden;
        }
        .orb-icon img { width: 100%; height: 100%; object-fit: cover; }

        @keyframes orbit-anim {
            from { transform: rotate(0deg) translateX(90px) rotate(0deg); }
            to { transform: rotate(360deg) translateX(90px) rotate(-360deg); }
        }

        .o-1 { animation-delay: 0s; } .o-2 { animation-delay: -3s; } .o-3 { animation-delay: -6s; } .o-4 { animation-delay: -9s; } .o-5 { animation-delay: -12s; }

        .cursor { display: inline-block; width: 2px; height: 15px; background: var(--accent-blue); margin-left: 2px; animation: blink 0.8s infinite; }
        @keyframes blink { 50% { opacity: 0; } }

        /* --- SOUND WAVE VISUALIZER --- */
        .sound-wave {
            position: absolute;
            top: 20px;
            left: 24px;
            display: flex;
            align-items: flex-end;
            gap: 2px;
            height: 20px;
        }
        .wave-bar {
            width: 3px;
            background: var(--accent-blue);
            height: 100%;
            border-radius: 10px;
            animation: wave-anim 1s ease-in-out infinite;
            animation-play-state: paused;
        }
        .bar-1 { height: 40%; animation-delay: 0.1s; }
        .bar-2 { height: 80%; animation-delay: 0.3s; }
        .bar-3 { height: 60%; animation-delay: 0.2s; }
        .bar-4 { height: 90%; animation-delay: 0.4s; }
        .bar-5 { height: 50%; animation-delay: 0.1s; }
        @keyframes wave-anim {
            0%, 100% { transform: scaleY(0.5); opacity: 0.5; }
            50% { transform: scaleY(1.5); opacity: 1; }
        }
        .wave-active .wave-bar { animation-play-state: running; }

        /* --- MUSIC PLAYER STYLE UPDATED --- */
        .music-player { text-align: center; padding: 10px 0; }
        .vinyl-container {
            width: 180px; height: 180px; margin: 0 auto 15px;
            border-radius: 50%; overflow: hidden;
            border: 6px solid rgba(255,255,255,0.1);
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
            cursor: grab;
            transform-origin: center center;
            touch-action: none;
        }
        .vinyl-container:active { cursor: grabbing; }
        .vinyl-container img { width: 100%; height: 100%; object-fit: cover; pointer-events: none; }
        
        .music-controls { display: flex; align-items: center; justify-content: center; gap: 15px; margin-top: 10px; }
        .btn-control { width: 24px; height: 24px; cursor: pointer; transition: transform 0.2s; opacity: 0.8; }
        .btn-control:hover { opacity: 1; }
        .btn-control:active { transform: scale(0.9); }
        .play-btn { width: 32px; height: 32px; }

        .seek-container { display: flex; align-items: center; gap: 10px; width: 90%; margin: 15px auto 5px; }
        .time-stamp { font-size: 10px; font-family: 'JetBrains Mono', monospace; color: #64748b; min-width: 35px; }
        
        .seek-bar {
            flex-grow: 1; height: 4px;
            background: rgba(255,255,255,0.1); border-radius: 2px;
            position: relative; cursor: pointer;
            touch-action: none; 
        }

        .seek-fill { 
            height: 100%; background: var(--accent-blue); width: 0%; border-radius: 2px; 
            position: relative; 
        }
        .seek-fill::after {
            content: '';
            position: absolute;
            right: -6px;
            top: 50%;
            transform: translateY(-50%);
            width: 12px;
            height: 12px;
            background: #ffffff;
            border-radius: 50%;
            box-shadow: 0 1px 4px rgba(0,0,0,0.4);
            transition: transform 0.15s ease;
        }
        .seek-bar:hover .seek-fill::after,
        .seek-bar:active .seek-fill::after {
            transform: translateY(-50%) scale(1.3);
        }

        /* Footer & Folder */
        .folder-gen {
            font-size: 6rem; display: block; margin-bottom: 20px;
            animation: folder-glow 2s infinite ease-in-out;
            filter: drop-shadow(0 0 10px rgba(59, 130, 246, 0.4));
        }
        @keyframes folder-glow {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.1); opacity: 1; filter: drop-shadow(0 0 25px rgba(59, 130, 246, 0.8)); }
        }
        footer { width: 100%; text-align: center; padding: 40px 0; }
        .yt-link {
            display: inline-flex; align-items: center; gap: 8px; background: rgba(255, 0, 0, 0.1);
            border: 1px solid rgba(255, 0, 0, 0.2); padding: 8px 16px; border-radius: 12px;
            color: #ff4d4d; font-weight: 600; transition: all 0.3s ease; margin-bottom: 15px;
        }
    </style>
</head>
